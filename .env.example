# Current Supply — required environment variables
# Copy to `.env.local` for local dev (never commit secrets).
# Canonical Vercel project: mcs-projects / current-supply → https://current-supply-sigma.vercel.app
# Set these for Production + Preview + Development in Vercel → Settings → Environment Variables.

# Public API URL (this project)
NEXT_PUBLIC_SUPABASE_URL=https://onjguvlozsqxkurgqgbl.supabase.co

# Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings → API → Project API keys → service_role (secret)
# Required for /api/categories, /api/deals, and Storage uploads
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Postgres URI if you want SQL bootstrap via DATABASE_URL
# DATABASE_URL=

# Optional: Google Sheets auto-sync (Deals tab)
# Requires a SERVICE ACCOUNT JSON key — OAuth "Web application" Client ID/Secret
# will NOT work for unattended sync on Vercel.
# 1. Enable Google Sheets API in Google Cloud Console
# 2. Create a service account → Keys → Add JSON key (use client_email + private_key)
# 3. Create a Sheet with a tab named exactly: Deals
# 4. Share the sheet with client_email as Editor
# 5. Set these on Vercel (Production + Preview), redeploy, then Finance → Sync
# GOOGLE_SHEETS_SPREADSHEET_ID=   # from https://docs.google.com/spreadsheets/d/<ID>/edit
# GOOGLE_SERVICE_ACCOUNT_EMAIL=   # client_email from the JSON key
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

