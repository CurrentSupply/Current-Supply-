# Current Supply — required environment variables
# Copy to `.env.local` for local dev (never commit secrets).
# Also set these in Vercel → Project → Settings → Environment Variables.

# Public API URL (this project)
NEXT_PUBLIC_SUPABASE_URL=https://onjguvlozsqxkurgqgbl.supabase.co

# Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings → API → Project API keys → service_role (secret)
# Used server-side for DB bootstrap helpers and Storage uploads
SUPABASE_SERVICE_ROLE_KEY=

# Project Settings → Database → Connection string → URI (Transaction pooler recommended)
# Example: postgresql://postgres.onjguvlozsqxkurgqgbl:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Optional alternative to DATABASE_URL if you only have the DB password:
# SUPABASE_DB_PASSWORD=
